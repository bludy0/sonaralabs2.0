# ─────────────────────────────────────────────────────────────────────────────
# SONARALABS 2.0 — Environment Variables
# Kopyala: cp .env.example .env  →  gerçek değerleri doldur
# .env dosyasını asla commit etme!
# ─────────────────────────────────────────────────────────────────────────────

# ── MONGODB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=changeme_in_prod

# ── POSTGRESQL (profile + social services) ────────────────────────────────────
POSTGRES_USER=sonaralabs
POSTGRES_PASS=sonaralabs_dev
# Docker Compose infers this from POSTGRES_USER/PASS above.
# Set manually when running services outside Docker:
DATABASE_URL=postgresql://sonaralabs:sonaralabs_dev@localhost:5432/sonaralabs

# ── REDIS ─────────────────────────────────────────────────────────────────────
# docker-compose içinde otomatik set edilir; dışarıdan çalıştırırken gerekmez
# REDIS_URL=redis://localhost:6379

# ── MINIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_in_prod

# ── JWT SECRETS ───────────────────────────────────────────────────────────────
# Üret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ÖNEMLİ: Üç secret birbirinden FARKLI olmalı!
ACCESS_JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
REFRESH_JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
INTERNAL_JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64

# ── CORS / CLIENT ─────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── EMAIL (Resend — https://resend.com, ücretsiz 3000/ay) ────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_YOUR_RESEND_API_KEY
EMAIL_FROM=Sonaralabs <noreply@yourdomain.com>
APP_URL=http://localhost:5174

# ── AI PROVIDERS ──────────────────────────────────────────────────────────────

# Beatoven.ai — müzik üretimi (https://beatoven.ai)
BEATOVEN_API_KEY=

# Sonauto — müzik üretimi (https://sonauto.ai/developers)
SONAUTO_API_KEY=

# Google Gemini — görüntü analizi + MIDI + mastering (https://aistudio.google.com)
# Ücretsiz tier: 1500 istek/gün
GEMINI_API_KEY=

# ElevenLabs — SFX üretimi, Starter plan gerekir ($5/ay)
# (https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=

# ── JOB CONFIG ────────────────────────────────────────────────────────────────
JOB_TIMEOUT_MS=300000          # 5 dakika

# ── RATE LIMIT (istek/dakika) ─────────────────────────────────────────────────
RATE_LIMIT_GENERAL=30          # Genel — kullanıcı başına
RATE_LIMIT_GENERATION=3        # POST /api/generate — kullanıcı başına
RATE_LIMIT_UPLOAD=10           # POST /api/upload — kullanıcı başına
RATE_LIMIT_AUTH=10             # POST /api/auth/* — IP başına (15dk pencere)

# ── STORAGE ───────────────────────────────────────────────────────────────────
STORAGE_QUOTA_BYTES=524288000  # 500 MB per user
MAX_FILE_SIZE_BYTES=52428800   # 50 MB per file

# ── CREDITS ───────────────────────────────────────────────────────────────────
INITIAL_CREDIT_BALANCE=100

# ── STRIPE ────────────────────────────────────────────────────────────────────
# Üret: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Üret: stripe listen --forward-to localhost:3005/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── FRONTEND ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter sonaralabs-frontend build",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "env": {
    "VITE_API_BASE_URL": "https://sonaralabs-gateway.onrender.com"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sonaralabs-gateway.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
